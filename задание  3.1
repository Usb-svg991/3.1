// ТИПЫ

type Currency = "RUB"
type Money = {amount: number; currency: Currency}
type InvoiceStatus = "draft" | "issued" | "paid" | "void"
type PaymentResult =
    | {ok: true; paidAt: string}
    | {ok: false; reason: "declined" | "network_error"}

type Discount = 
    | { kind: "percent"; value: number }
    | { kind: "fixed"; valueRub: number }

interface PaymentMethod {
    pay(invoice: Invoice, amount: Money): PaymentResult
}

interface Billable {
    title: string
    total(): Money
}

abstract class InvoiceLine implements Billable {
    public readonly title: string

    protected constructor(title: string, protected readonly qty: number) {
        this.title = title
    }

    protected abstract unitPrice(): Money

    public total(): Money {
        const price = this.unitPrice()
        return {amount: price.amount * this.qty, currency: price.currency}
    }
}

class LaborLine extends InvoiceLine {
    constructor(title: string, qtyHours: number, private readonly rubPerHour: number){
        super(title, qtyHours)
    }
    protected unitPrice(): Money {
        return {amount: this.rubPerHour, currency: "RUB"}
    }
}

class Invoice {
    private status: InvoiceStatus = "draft"
    private discount?: Discount

    constructor(public readonly id: string, private readonly lines: Billable[]){}

    public issue(): void{
        if (this.status !== "draft") {
            throw new Error("Can issue only from draft")
        }
        this.status = "issued"
    }
    
    public markPaid(): void{
        if (this.status !== "issued") {
            throw new Error("Can mark as paid only from issued")
        }
        this.status = "paid"
    }
    
    public getStatus(): InvoiceStatus{
        return this.status
    }
    
    public getLines(): readonly Billable[]{
        return this.lines
    }

    public setDiscount(discount: Discount): void {
        this.discount = discount
    }

    public getDiscount(): Discount | undefined {
        return this.discount
    }
}

class CashPayment implements PaymentMethod{
    pay(invoice: Invoice, amount: Money): PaymentResult{
        if (invoice.getStatus() !== "issued"){
            return {ok: false, reason: "declined"}
        }
        return { ok: true, paidAt: new Date().toISOString()} 
    }
}

class InvoiceCalculator {
    public sum(lines: readonly Billable[], discount?: Discount): Money {
        const subtotal = lines.reduce(
            (acc, line) => {
                const lineTotal = line.total()
                return {
                    amount: acc.amount + lineTotal.amount, 
                    currency: "RUB" as Currency
                }
            },
            {amount: 0, currency: "RUB" as Currency}
        )

        if (!discount) {
            return subtotal
        }

        let discountAmount: number
        
        switch (discount.kind) {
            case "percent":
                discountAmount = (subtotal.amount * discount.value) / 100
                break
            case "fixed":
                discountAmount = discount.valueRub
                break
        }

        return {
            amount: Math.max(0, subtotal.amount - discountAmount),
            currency: "RUB" as Currency
        }
    }
}

function demo(): Invoice {
    const lines = [
        new LaborLine("Overtime job", 2, 100),
        new LaborLine("Consulting", 4, 200),
        new LaborLine("Development", 10, 443),
        new LaborLine("Testing", 2, 1500)
    ]
    const invoice = new Invoice("INV-2026-0001", lines)
    
    // Пример применения скидки
    invoice.setDiscount({ kind: "percent", value: 10 }) // 10% скидка
    
    return invoice
}

function getResult(invoice: Invoice): void {
    invoice.issue()
    const calculator = new InvoiceCalculator()

    const total: Money = calculator.sum(invoice.getLines(), invoice.getDiscount())

    const payment = new CashPayment()
    const result = payment.pay(invoice, total)

    console.log("Total with discount:", total)
    console.log("Invoice:", invoice)
    console.log("Payment result:", result)
}

const invoice = demo()
getResult(invoice)
